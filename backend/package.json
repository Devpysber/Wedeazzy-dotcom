{
  "name": "wedeazzy-backend",
  "version": "0.1.0",
  "private": true,
  "description": "WedEazzy.com SaaS backend - Node + Express + Prisma + MySQL + Baileys WhatsApp",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "jest --runInBand --forceExit",
    "start:prod": "prisma migrate deploy && prisma generate && node src/server.js",
    "prisma:gen": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:fix": "node src/scripts/fix-schema.js",
    "seed": "node src/scripts/seed-vendors.js",
    "seed:admin": "node src/scripts/seed-admin.js",
    "seed:demo": "node src/scripts/seed-demo.js",
    "seed:vendors": "node src/scripts/seed-vendors.js ../public/js/vendors.csv"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@whiskeysockets/baileys": "^6.7.18",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.5",
    "cookie-session": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "mysql2": "^3.22.5",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.13",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pino": "^9.6.0",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "uuid": "^11.0.4"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.9",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2"
  }
}
