# WedEazzy backend — environment variable template.
# Copy this file to `.env` and fill in real values. NEVER commit the real .env.
#   cp .env.example .env

# --- Server ---
NODE_ENV=production
PORT=4000
PUBLIC_BASE_URL=
# Comma-separated list of origins allowed to call the API
FRONTEND_ORIGIN=

# --- Database (MySQL) ---
# Format: mysql://USER:PASS@HOST:PORT/DB
DATABASE_URL=

# --- JWT ---
JWT_SECRET=
JWT_EXPIRES_IN=30d

# --- OTP ---
OTP_TTL_MIN=5
OTP_MAX_PER_HOUR=5
OTP_LENGTH=6
# Keep FALSE in production (true enables the 123456 debug OTP backdoor)
OTP_DEBUG_LOG=false

# --- Baileys / WhatsApp ---
BAILEYS_AUTH_DIR=./baileys-auth
WA_MAX_RECONNECT_ATTEMPTS=10
WA_RECONNECT_BASE_MS=3000
WA_RETRY_MAX_ATTEMPTS=3
WA_RETRY_BACKOFF_MS=300000

# --- Admin ---
# Phones (E.164) that get role=admin automatically when they verify OTP.
ADMIN_PHONES=
# Admin seed account credentials (used by `npm run seed:admin`).
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Recipient for support/alert notifications (falls back to ADMIN_EMAIL if unset)
SUPPORT_EMAIL=

# --- Legacy vendor import (one-off migration script only) ---
LEGACY_DB_PASSWORD=

# --- Uploads ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=5

# --- Razorpay Payment Gateway ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- SMTP Email Configuration ---
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=WedEazzy <info@wedeazzy.com>
SMTP_SECURE=true

# --- Google OAuth Credentials ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# --- Google Sheet CSV Source ---
GOOGLE_SHEET_CSV_URL=
